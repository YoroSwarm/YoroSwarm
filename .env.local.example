# Database
DATABASE_URL="file:./dev.db"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
NEXT_PUBLIC_JWT_SECRET=your-secret-key-here

# App Configuration
NEXT_PUBLIC_APP_NAME=Swarm
NEXT_PUBLIC_APP_VERSION=1.0.0

# API Configuration (internal API - no longer needed for backend)
NEXT_PUBLIC_API_URL=/api
# WebSocket (uses same port as HTTP - e.g., ws://localhost:3000/ws)
# Leave empty to auto-detect from browser location
NEXT_PUBLIC_WS_URL=

# File Upload
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE=104857600

# LLM Configuration
# All LLM API keys and model settings are managed per-user in the web UI settings.
# No environment variables are needed for LLM configuration.

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
