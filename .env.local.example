# Database
DATABASE_URL="file:./dev.db"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
NEXT_PUBLIC_JWT_SECRET=your-secret-key-here

# App Configuration
NEXT_PUBLIC_APP_NAME=Swarm
NEXT_PUBLIC_APP_VERSION=1.0.0

# API Configuration (internal API - no longer needed for backend)
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WS_URL=ws://localhost:3000/api/ws

# File Upload
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE=104857600

# LLM Configuration
# Provider: 'anthropic' or 'openai' (auto-detected from API key if not set)
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_BASE_URL=          # Optional custom base URL

# OpenAI (uncomment to use OpenAI instead)
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=             # Optional: custom base URL (e.g. for Azure, vLLM, Ollama)

# Model Configuration
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
# LLM_MAX_CONTEXT_TOKENS=     # Optional: override model context window size

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
