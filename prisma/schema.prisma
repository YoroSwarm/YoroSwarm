// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// 用户和认证模块
// ============================================

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  email          String    @unique
  hashedPassword String    @map("hashed_password")
  isActive       Boolean   @default(true) @map("is_active")
  isSuperuser    Boolean   @default(false) @map("is_superuser")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastLogin      DateTime? @map("last_login")

  // Relations
  sessions      Session[]
  swarmSessions SwarmSession[]
  externalConversations ExternalConversation[]
  files         File[]

  @@map("users")
}

model Session {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  refreshToken String    @unique @map("refresh_token")
  sessionId    String    @unique @map("session_id")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  isActive     Boolean   @default(true) @map("is_active")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime  @default(now()) @map("last_used_at")

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  files File[]

  @@map("sessions")
}

model SwarmSession {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  title       String
  goal        String?
  status      SwarmSessionStatus @default(ACTIVE)
  mode        String             @default("general_office")
  leadAgentId String?            @unique @map("lead_agent_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  archivedAt  DateTime?          @map("archived_at")

  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadAgent             Agent?                @relation("LeadAgent", fields: [leadAgentId], references: [id], onDelete: SetNull)
  agents                Agent[]
  agentContextEntries   AgentContextEntry[]
  tasks                 TeamLeadTask[]
  taskDependencies      TaskDependency[]
  internalThreads       InternalThread[]
  internalMessages      InternalMessage[]
  externalConversations ExternalConversation[]
  externalMessages      ExternalMessage[]
  files                 File[]
  leadSelfTodos         LeadSelfTodo[]
  llmUsageEvents        LlmUsageEvent[]
  sharedKnowledgeEntries SharedKnowledgeEntry[]

  @@map("swarm_sessions")
}

// ============================================
// 文件模块
// ============================================

model File {
  id           String   @id @default(uuid())
  filename     String
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  path         String
  sessionId    String   @map("session_id")
  swarmSessionId String @map("swarm_session_id")
  userId       String?  @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  metadata     String? // JSON string

  // Relations
  session   Session        @relation(fields: [sessionId], references: [id])
  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id])
  thumbnails FileThumbnail[]

  @@map("files")
}

model FileThumbnail {
  id      String @id @default(uuid())
  fileId  String @map("file_id")
  size    String // small, medium, large
  width   Int
  height  Int
  path    String

  // Relations
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("file_thumbnails")
}

// ============================================
// Team Lead 模块
// ============================================

enum TeamLeadAgentStatus {
  IDLE
  BUSY
  OFFLINE
  ERROR
}

enum TeamLeadTaskStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum SwarmSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
  FAILED
}

enum AgentKind {
  LEAD
  RESEARCHER
  WRITER
  ANALYST
  ENGINEER
  COORDINATOR
  SPECIALIST
  WORKER
}

model Agent {
  id          String              @id @default(uuid())
  swarmSessionId String           @map("swarm_session_id")
  name        String
  role        String
  kind        AgentKind           @default(WORKER)
  description String?
  status      TeamLeadAgentStatus @default(IDLE)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  // Configuration
  capabilities String? // JSON array
  config       String  @default("{}") // JSON string

  // Relations
  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  leadForSessions SwarmSession[]   @relation("LeadAgent")
  contextEntries AgentContextEntry[]
  tasks          TeamLeadTask[]    @relation("AgentTasks")
  createdTasks   TeamLeadTask[]    @relation("CreatedTasks")
  sentInternalMessages InternalMessage[] @relation("InternalMessageSender")
  receivedInternalMessages InternalMessage[] @relation("InternalMessageRecipient")
  externalConversationsAsLead ExternalConversation[] @relation("ExternalConversationLead")
  leadSelfTodos        LeadSelfTodo[]
  llmUsageEvents       LlmUsageEvent[]

  @@index([swarmSessionId])
  @@map("agents")
}

model AgentContextEntry {
  id             String   @id @default(uuid())
  swarmSessionId String   @map("swarm_session_id")
  agentId        String   @map("agent_id")
  sourceType     String   @map("source_type")
  sourceId       String?  @map("source_id")
  entryType      String   @map("entry_type")
  content        String
  metadata       String?
  visibility     String   @default("private")
  sequence       Int
  createdAt      DateTime @default(now()) @map("created_at")

  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, sequence])
  @@index([swarmSessionId, agentId, createdAt])
  @@map("agent_context_entries")
}

model TeamLeadTask {
  id          String             @id @default(uuid())
  swarmSessionId String          @map("swarm_session_id")
  title       String
  description String?
  status      TeamLeadTaskStatus @default(PENDING)
  priority    Int                @default(2) // 1-4: LOW, MEDIUM, HIGH, CRITICAL
  assigneeId  String?            @map("assignee_id")
  creatorId   String             @map("creator_id")
  parentId    String?            @map("parent_id")
  resultSummary String?          @map("result_summary")
  errorSummary String?           @map("error_summary")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  startedAt   DateTime?          @map("started_at")
  completedAt DateTime?          @map("completed_at")
  dueDate     DateTime?          @map("due_date")

  // Relations
  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  assignee     Agent?           @relation("AgentTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator      Agent            @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: Cascade)
  parent       TeamLeadTask?    @relation("TaskTree", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks     TeamLeadTask[]   @relation("TaskTree")
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")
  internalThreads InternalThread[]

  @@index([swarmSessionId, status])
  @@map("team_lead_tasks")
}

model LeadSelfTodo {
  id             String   @id @default(uuid())
  swarmSessionId String   @map("swarm_session_id")
  leadAgentId    String   @map("lead_agent_id")
  title          String
  details        String?
  status         String   @default("pending")
  category       String   @default("other")
  sourceRef      String?  @map("source_ref")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  completedAt    DateTime? @map("completed_at")

  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  leadAgent    Agent        @relation(fields: [leadAgentId], references: [id], onDelete: Cascade)

  @@index([swarmSessionId, leadAgentId, status])
  @@index([swarmSessionId, sortOrder])
  @@map("lead_self_todos")
}

model LlmUsageEvent {
  id                  String   @id @default(uuid())
  swarmSessionId      String   @map("swarm_session_id")
  agentId             String?  @map("agent_id")
  provider            String
  model               String
  requestKind         String   @default("general") @map("request_kind")
  inputTokens         Int      @default(0) @map("input_tokens")
  outputTokens        Int      @default(0) @map("output_tokens")
  cacheCreationTokens Int      @default(0) @map("cache_creation_tokens")
  cacheReadTokens     Int      @default(0) @map("cache_read_tokens")
  createdAt           DateTime @default(now()) @map("created_at")

  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([swarmSessionId, createdAt])
  @@index([swarmSessionId, agentId, createdAt])
  @@map("llm_usage_events")
}

model TaskDependency {
  id              String   @id @default(uuid())
  swarmSessionId  String   @map("swarm_session_id")
  taskId          String   @map("task_id")
  dependsOnTaskId String   @map("depends_on_task_id")
  dependencyType  String   @default("blocks") @map("dependency_type")

  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  task         TeamLeadTask  @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask TeamLeadTask @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([swarmSessionId, taskId])
  @@map("task_dependencies")
}

model InternalThread {
  id             String   @id @default(uuid())
  swarmSessionId String   @map("swarm_session_id")
  threadType     String   @map("thread_type")
  subject        String?
  relatedTaskId  String?  @map("related_task_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  swarmSession SwarmSession  @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  relatedTask  TeamLeadTask? @relation(fields: [relatedTaskId], references: [id], onDelete: SetNull)
  messages     InternalMessage[]

  @@index([swarmSessionId, createdAt])
  @@map("internal_threads")
}

model InternalMessage {
  id               String    @id @default(uuid())
  swarmSessionId   String    @map("swarm_session_id")
  threadId         String    @map("thread_id")
  senderAgentId    String    @map("sender_agent_id")
  recipientAgentId String?   @map("recipient_agent_id")
  messageType      String    @map("message_type")
  content          String
  metadata         String?
  createdAt        DateTime  @default(now()) @map("created_at")
  readAt           DateTime? @map("read_at")

  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  thread       InternalThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender       Agent @relation("InternalMessageSender", fields: [senderAgentId], references: [id], onDelete: Cascade)
  recipient    Agent? @relation("InternalMessageRecipient", fields: [recipientAgentId], references: [id], onDelete: SetNull)

  @@index([swarmSessionId, threadId, createdAt])
  @@map("internal_messages")
}

model ExternalConversation {
  id             String   @id @default(uuid())
  swarmSessionId String   @map("swarm_session_id")
  userId         String   @map("user_id")
  leadAgentId    String   @map("lead_agent_id")
  title          String
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadAgent    Agent @relation("ExternalConversationLead", fields: [leadAgentId], references: [id], onDelete: Cascade)
  messages     ExternalMessage[]

  @@index([swarmSessionId, userId])
  @@map("external_conversations")
}

model ExternalMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  swarmSessionId String   @map("swarm_session_id")
  senderType     String   @map("sender_type")
  senderId       String?  @map("sender_id")
  content        String
  messageType    String   @default("text") @map("message_type")
  metadata       String?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation ExternalConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  swarmSession SwarmSession         @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)

  @@index([swarmSessionId, conversationId, createdAt])
  @@map("external_messages")
}

// ============================================
// 共享知识层 (Shared Knowledge Layer)
// ============================================

model SharedKnowledgeEntry {
  id             String   @id @default(uuid())
  swarmSessionId String   @map("swarm_session_id")
  taskId         String?  @map("task_id")
  agentId        String   @map("agent_id")
  entryType      String   @map("entry_type") // task_result, discovery, resource, fact
  title          String
  content        String
  summary        String?
  tags           String?  // JSON array of tags
  confidence     Float    @default(1.0)
  createdAt      DateTime @default(now()) @map("created_at")

  swarmSession SwarmSession @relation(fields: [swarmSessionId], references: [id], onDelete: Cascade)

  @@index([swarmSessionId, entryType])
  @@index([swarmSessionId, taskId])
  @@map("shared_knowledge_entries")
}


// ============================================
// 共享任务列表模块 (Shared Task List)
// ============================================

enum SharedTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model SharedTask {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  status      SharedTaskStatus @default(PENDING)
  priority    Int             @default(2) // 1-4
  assigneeId  String?         @map("assignee_id")
  creatorId   String          @map("creator_id")
  parentId    Int?            @map("parent_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  startedAt   DateTime?       @map("started_at")
  completedAt DateTime?       @map("completed_at")
  dueDate     DateTime?       @map("due_date")

  // Relations
  parent   SharedTask?  @relation("SharedTaskDependencies", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks SharedTask[] @relation("SharedTaskDependencies")

  @@map("shared_tasks")
}
